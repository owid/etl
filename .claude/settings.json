{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(find:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/remote_setup.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && out=$(make check 2>&1) || { echo \"$out\" >&2; exit 2; }",
            "if": "Bash(git commit *)",
            "statusMessage": "make check (pre-commit)"
          }
        ]
      }
    ]
  }
}
